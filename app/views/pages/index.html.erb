<section id="hero">
  <div class="hero-content">
    <div class="hero-line"></div>
    <div class="hero-tag">Développeuse web · Culture & Artisanat</div>
    <h1>Je construis des sites<br>qui <em>résonnent</em><br>avec votre univers.</h1>
    <div class="hero-bottom">
      <p class="hero-desc">Formée au Wagon, nourrie par 15 ans de direction musicale. Je code des expériences web sur-mesure pour les acteurs culturels et artisanaux.</p>
      <div class="hero-cta">
        <%= link_to "Voir les projets →", projects_path, class: "btn-cta" %>
        <%= link_to "Me contacter", new_contact_path, class: "btn-cta-filled" %>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<section id="about">
  <div class="section-header">
    <span class="section-num">01</span>
    <span class="section-title">À propos</span>
  </div>
  <div class="about-grid">
    <div class="about-left">
      <div class="about-label">Développeuse</div>
      <div class="about-name">Prénom<br><em>Nom</em></div>
      <div class="about-photo">
        <%# Remplace par ton image : %>
        <%# <%= image_tag "photo.jpg", alt: "Prénom Nom" %> %>
        <div class="photo-placeholder">◻ Votre photo</div>
      </div>
    </div>
    <div class="about-right">
      <p class="about-bio">Code et <em>musique</em> partagent la même logique : structure, rythme, et l'art de faire ressentir quelque chose.</p>
      <p class="about-body">Directrice d'école de musique depuis plus de 15 ans, j'ai rejoint Le Wagon en 2025 pour transformer ma compréhension du monde culturel en compétence technique.</p>
      <p class="about-body">Je crée des sites qui reflètent fidèlement l'identité de leurs commanditaires, avec un vrai soin du détail et de l'expérience utilisateur.</p>
      <div class="skills-row">
        <span class="skill-chip hl">Ruby on Rails</span>
        <span class="skill-chip hl">JavaScript</span>
        <span class="skill-chip hl">HTML / CSS</span>
        <span class="skill-chip">PostgreSQL</span>
        <span class="skill-chip">Stimulus</span>
        <span class="skill-chip">Figma</span>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<section id="services">
  <div class="section-header">
    <span class="section-num">02</span>
    <span class="section-title">Services</span>
  </div>
  <div class="services-list">
    <div class="service-item">
      <span class="svc-num">01</span>
      <div class="svc-body">
        <h3>Site vitrine culturel</h3>
        <p>Pour les écoles de musique, théâtres, galeries, festivals et associations culturelles.</p>
      </div>
      <span class="svc-price">Sur devis</span>
    </div>
    <div class="service-item">
      <span class="svc-num">02</span>
      <div class="svc-body">
        <h3>Vitrine artisanale & créatrice</h3>
        <p>Pour les céramistes, luthiers, joailliers, designers et créateurs.</p>
      </div>
      <span class="svc-price">Sur devis</span>
    </div>
    <div class="service-item">
      <span class="svc-num">03</span>
      <div class="svc-body">
        <h3>Refonte & optimisation</h3>
        <p>Audit, modernisation du design, performances et accessibilité.</p>
      </div>
      <span class="svc-price">À partir de 800 €</span>
    </div>
    <div class="service-item">
      <span class="svc-num">04</span>
      <div class="svc-body">
        <h3>Landing page & one-pager</h3>
        <p>Une page percutante, livrée en 2 semaines, pensée pour convertir.</p>
      </div>
      <span class="svc-price">À partir de 400 €</span>
    </div>
  </div>
</section>

<div class="divider"></div>

<section id="portfolio-preview">
  <div class="section-header">
    <span class="section-num">03</span>
    <span class="section-title">Projets récents</span>
  </div>
  <div class="projects-list">
    <% @projects.each do |project| %>
      <%= render "projects/card", project: project %>
    <% end %>
  </div>
  <%= link_to "Voir tous les projets →", projects_path, class: "btn-cta" %>
</section>
